NODE_ENV=development

# =========================================================
# RotaPronta - ambiente local / development
# Copie este arquivo para ".env" na raiz do monorepo.
# =========================================================

# Backend HTTP
PORT=3000
HOST=0.0.0.0
API_PREFIX=api

# Banco local via Docker Compose
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/delivery_platform?schema=public

# JWT local
JWT_SECRET=rotapronta-chave-local-123
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# Primeiro admin interno da plataforma
# Usado apenas pelo script: pnpm --filter @deliveries/backend admin:create
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
PLATFORM_ADMIN_NAME=
PLATFORM_ADMIN_PHONE=
# Opcional: permite promover usuario existente para PLATFORM_ADMIN de forma explicita.
PLATFORM_ADMIN_ALLOW_PROMOTE=false

# Google auth opcional para o app do motoboy
# Use o client ID Android da sua app e repita no backend em GOOGLE_AUTH_AUDIENCES.
GOOGLE_AUTH_AUDIENCES=

# Observabilidade local opcional
# Se definido, habilita GET /api/internal/metrics com este token.
OPERATIONAL_METRICS_TOKEN=replace-with-local-metrics-token

# Observabilidade externa opcional
# Sem SENTRY_DSN, o backend roda normalmente sem enviar erros externos.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_RELEASE=rotapronta-local

# Endpoint interno opcional para validar um erro 5xx real no Sentry.
# So habilite temporariamente quando quiser testar a integracao.
ENABLE_SENTRY_TEST_ENDPOINT=false

# Comprovantes Pix manuais - desenvolvimento local
# Use "local" em desenvolvimento. Em producao, prefira "s3" com Cloudflare R2/S3.
PAYMENT_PROOF_STORAGE_DRIVER=local
PAYMENT_PROOF_STORAGE_DIR=./storage/payment-proofs
PAYMENT_PROOF_S3_ENDPOINT=
PAYMENT_PROOF_S3_REGION=auto
PAYMENT_PROOF_S3_BUCKET=
PAYMENT_PROOF_S3_ACCESS_KEY_ID=
PAYMENT_PROOF_S3_SECRET_ACCESS_KEY=
PAYMENT_PROOF_S3_FORCE_PATH_STYLE=true

# Imagens de loja, produtos e perfil do motoboy
# Se vazio, reutiliza o mesmo driver/credenciais de PAYMENT_PROOF_*.
IMAGE_STORAGE_DRIVER=local
IMAGE_STORAGE_DIR=./storage/images
IMAGE_S3_ENDPOINT=
IMAGE_S3_REGION=auto
IMAGE_S3_BUCKET=
IMAGE_S3_ACCESS_KEY_ID=
IMAGE_S3_SECRET_ACCESS_KEY=
IMAGE_S3_FORCE_PATH_STYLE=true

# CORS local
CORS_ORIGIN_DESKTOP=http://localhost:5173
CORS_ORIGIN_MOBILE=exp://127.0.0.1:8081
CORS_ALLOWED_ORIGINS=http://localhost:5173,exp://127.0.0.1:8081

# Desktop - variaveis usadas pelo renderer em development
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
ELECTRON_RENDERER_URL=http://localhost:5173

# Mobile - variaveis usadas pelo Expo em development
# Em celular fisico, troque localhost pelo IP da sua maquina.
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
