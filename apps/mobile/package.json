{
  "name": "@deliveries/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "tsc -p tsconfig.json --noEmit",
    "prepare:eas-archive": "node scripts/prepare-eas-archive.cjs",
    "build:android:preview": "pnpm prepare:eas-archive && pnpm dlx eas-cli build --platform android --profile preview",
    "build:android:production": "pnpm prepare:eas-archive && pnpm dlx eas-cli build --platform android --profile production --clear-cache",
    "config:check": "expo config --type public",
    "lint": "eslint \"app/**/*.{ts,tsx}\" \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "if exist .expo rmdir /s /q .expo"
  },
  "dependencies": {
    "@deliveries/shared-types": "workspace:*",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@react-navigation/bottom-tabs": "^7.4.2",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/native-stack": "^7.3.25",
    "expo": "^53.0.0",
    "expo-image-picker": "~16.1.4",
    "expo-secure-store": "^14.2.4",
    "expo-status-bar": "^2.2.3",
    "react": "19.0.0",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@react-native-community/cli": "18.0.0",
    "@react-native-community/cli-platform-android": "18.0.0",
    "@types/react": "~19.0.10",
    "typescript": "~5.8.3"
  }
}
