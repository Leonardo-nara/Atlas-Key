NODE_ENV=production

# =========================================================
# RotaPronta - ambiente de production
# Use este arquivo como base para deploy e builds publicados.
# =========================================================

# Backend HTTP
PORT=3000
HOST=0.0.0.0
API_PREFIX=api

# Banco de producao
DATABASE_URL=postgresql://postgres:strong-password@db-host:5432/delivery_platform?schema=public

# JWT de producao
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# Google auth opcional para o app do motoboy
# Use o client ID Android do Google Cloud Console.
GOOGLE_AUTH_AUDIENCES=

# Observabilidade operacional
# Use um segredo forte. Sem esta env, /api/internal/metrics fica oculto.
OPERATIONAL_METRICS_TOKEN=replace-with-a-long-random-metrics-token

# Observabilidade externa opcional
# Configure no Render para ativar captura de erros no Sentry.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_RELEASE=rotapronta-backend

# Endpoint interno opcional para validar um erro 5xx real no Sentry.
# Mantenha false por padrao e ative apenas no momento do teste controlado.
ENABLE_SENTRY_TEST_ENDPOINT=false

# Comprovantes Pix manuais - storage persistente
# Em Render, use "s3" com Cloudflare R2/S3. "local" so e seguro com disco persistente.
PAYMENT_PROOF_STORAGE_DRIVER=s3
PAYMENT_PROOF_STORAGE_DIR=/var/data/rotapronta/payment-proofs
PAYMENT_PROOF_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
PAYMENT_PROOF_S3_REGION=auto
PAYMENT_PROOF_S3_BUCKET=rotapronta-payment-proofs
PAYMENT_PROOF_S3_ACCESS_KEY_ID=replace-with-r2-access-key-id
PAYMENT_PROOF_S3_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
PAYMENT_PROOF_S3_FORCE_PATH_STYLE=true

# CORS de producao
# Inclua aqui apenas dominios reais que vao consumir a API.
CORS_ALLOWED_ORIGINS=https://painel.rotapronta.com,https://admin.rotapronta.com,https://app.rotapronta.com

# Desktop - variaveis de build do renderer
VITE_API_URL=https://rotapronta-api.onrender.com/api
VITE_SOCKET_URL=https://rotapronta-api.onrender.com

# Mobile - variaveis de build do Expo/EAS
EXPO_PUBLIC_API_URL=https://rotapronta-api.onrender.com/api
EXPO_PUBLIC_SOCKET_URL=https://rotapronta-api.onrender.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
