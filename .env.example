NODE_ENV=development

# =========================================================
# RotaPronta - ambiente local / development
# Copie este arquivo para ".env" na raiz do monorepo.
# =========================================================

# Backend HTTP
PORT=3000
HOST=0.0.0.0
API_PREFIX=api

# Banco local via Docker Compose
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/delivery_platform?schema=public

# JWT local
JWT_SECRET=rotapronta-chave-local-123
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# Observabilidade local opcional
# Se definido, habilita GET /api/internal/metrics com este token.
OPERATIONAL_METRICS_TOKEN=replace-with-local-metrics-token

# Observabilidade externa opcional
# Sem SENTRY_DSN, o backend roda normalmente sem enviar erros externos.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_RELEASE=rotapronta-local

# Endpoint interno opcional para validar um erro 5xx real no Sentry.
# So habilite temporariamente quando quiser testar a integracao.
ENABLE_SENTRY_TEST_ENDPOINT=false

# CORS local
CORS_ORIGIN_DESKTOP=http://localhost:5173
CORS_ORIGIN_MOBILE=exp://127.0.0.1:8081
CORS_ALLOWED_ORIGINS=http://localhost:5173,exp://127.0.0.1:8081

# Desktop - variaveis usadas pelo renderer em development
VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
ELECTRON_RENDERER_URL=http://localhost:5173

# Mobile - variaveis usadas pelo Expo em development
# Em celular fisico, troque localhost pelo IP da sua maquina.
EXPO_PUBLIC_API_URL=http://localhost:3000/api
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
