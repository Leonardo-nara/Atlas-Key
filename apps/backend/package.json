{
  "name": "@deliveries/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:generate:prod": "prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:deploy:prod": "prisma migrate deploy",
    "prisma:seed": "dotenv -e ../../.env -- node prisma/seed.js",
    "prisma:seed:prod": "node prisma/seed.js",
    "build": "nest build",
    "build:prod": "pnpm prisma:generate:prod && pnpm build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "start:local": "dotenv -e ../../.env -- node dist/main.js",
    "dev": "nest start --watch",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "if exist dist rmdir /s /q dist"
  },
  "dependencies": {
    "@deliveries/shared-types": "workspace:*",
    "@nestjs/common": "^11.0.17",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.17",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.17",
    "@nestjs/platform-socket.io": "^11.0.17",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.0.17",
    "@prisma/client": "^6.6.0",
    "@sentry/nestjs": "^10.48.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^16.4.7",
    "google-auth-library": "^9.15.1",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@nestjs/schematics": "^11.0.1",
    "@types/passport-jwt": "^4.0.1",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.6.0"
  }
}
