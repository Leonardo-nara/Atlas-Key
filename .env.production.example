NODE_ENV=production

# =========================================================
# RotaPronta - ambiente de production
# Use este arquivo como base para deploy e builds publicados.
# =========================================================

# Backend HTTP
PORT=3000
HOST=0.0.0.0
API_PREFIX=api

# Banco de producao
DATABASE_URL=postgresql://postgres:strong-password@db-host:5432/delivery_platform?schema=public

# JWT de producao
JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# Observabilidade operacional
# Use um segredo forte. Sem esta env, /api/internal/metrics fica oculto.
OPERATIONAL_METRICS_TOKEN=replace-with-a-long-random-metrics-token

# CORS de producao
# Inclua aqui apenas dominios reais que vao consumir a API.
CORS_ALLOWED_ORIGINS=https://painel.rotapronta.com,https://admin.rotapronta.com,https://app.rotapronta.com

# Desktop - variaveis de build do renderer
VITE_API_URL=https://rotapronta-api.onrender.com/api
VITE_SOCKET_URL=https://rotapronta-api.onrender.com

# Mobile - variaveis de build do Expo/EAS
EXPO_PUBLIC_API_URL=https://rotapronta-api.onrender.com/api
EXPO_PUBLIC_SOCKET_URL=https://rotapronta-api.onrender.com
