generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STORE_ADMIN
  COURIER
}

enum CourierVehicleType {
  MOTO
  SCOOTER
  BICICLETA
  CARRO
}

enum StoreCourierLinkStatus {
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

enum StoreCourierLinkRequestedBy {
  COURIER
  STORE_ADMIN
}

enum OrderStatus {
  PENDING
  ACCEPTED
  ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum OrderEventType {
  CREATED
  ACCEPTED
  PICKED_UP
  DELIVERED
  CANCELLED
}

enum AuthAuditEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  REFRESH_SUCCESS
  REFRESH_FAILED
  LOGOUT
  LOGOUT_ALL
  SESSION_REVOKED
  SESSION_REVOKED_BY_USER
  SESSION_REVOKED_ADMIN
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String
  googleSub    String?  @unique
  googleEmailVerified Boolean @default(false)
  role         UserRole
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ownedStore    Store?
  courierProfile CourierProfile?
  storeLinks    StoreCourierLink[]
  courierOrders Order[] @relation("CourierOrders")
  orderEvents   OrderEvent[]
  authSessions  AuthSession[]
  authAuditEvents AuthAuditEvent[]

  @@map("users")
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String
  ipAddress        String?
  userAgent        String?
  revokedAt        DateTime?
  expiresAt        DateTime
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("auth_sessions")
}

model AuthAuditEvent {
  id        String             @id @default(cuid())
  userId    String?
  type      AuthAuditEventType
  email     String?
  ipAddress String?
  userAgent String?
  sessionId String?
  metadata  Json?
  createdAt DateTime           @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([email, createdAt])
  @@index([type, createdAt])
  @@map("auth_audit_events")
}

model CourierProfile {
  id               String              @id @default(cuid())
  userId           String              @unique
  profilePhotoUrl  String?
  vehiclePhotoUrl  String?
  vehicleType      CourierVehicleType?
  vehicleModel     String?
  plate            String?
  city             String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([city])
  @@index([vehicleType])
  @@map("courier_profiles")
}

model Store {
  id          String   @id @default(cuid())
  name        String
  address     String
  ownerUserId String   @unique
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User               @relation(fields: [ownerUserId], references: [id])
  products     Product[]
  orders       Order[]
  courierLinks StoreCourierLink[]

  @@map("stores")
}

model StoreCourierLink {
  id          String                      @id @default(cuid())
  courierId   String
  storeId     String
  status      StoreCourierLinkStatus     @default(PENDING)
  requestedBy StoreCourierLinkRequestedBy
  approvedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt

  courier User  @relation(fields: [courierId], references: [id], onDelete: Cascade)
  store   Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([courierId, storeId])
  @@index([storeId, status])
  @@index([courierId, status])
  @@map("store_courier_links")
}

model Product {
  id          String   @id @default(cuid())
  storeId     String
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  category    String
  imageUrl    String?
  available   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store      Store      @relation(fields: [storeId], references: [id])
  orderItems OrderItem[]

  @@index([storeId])
  @@map("products")
}

model Order {
  id              String      @id @default(cuid())
  storeId         String
  courierId       String?
  customerName    String
  customerPhone   String
  customerAddress String
  subtotal        Decimal     @db.Decimal(10, 2)
  deliveryFee     Decimal     @db.Decimal(10, 2)
  total           Decimal     @db.Decimal(10, 2)
  status          OrderStatus @default(PENDING)
  notes           String?
  cancelReason    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  store   Store       @relation(fields: [storeId], references: [id])
  courier User?       @relation("CourierOrders", fields: [courierId], references: [id])
  items   OrderItem[]
  events  OrderEvent[]

  @@index([storeId])
  @@index([courierId])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(cuid())
  orderId      String
  productId    String?
  nameSnapshot String
  quantity     Int
  unitPrice    Decimal @db.Decimal(10, 2)
  totalPrice   Decimal @db.Decimal(10, 2)

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderEvent {
  id          String         @id @default(cuid())
  orderId     String
  type        OrderEventType
  actorUserId String?
  actorRole   UserRole?
  metadata    Json?
  createdAt   DateTime       @default(now())

  order      Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actorUser  User? @relation(fields: [actorUserId], references: [id])

  @@index([orderId, createdAt])
  @@index([actorUserId])
  @@map("order_events")
}
